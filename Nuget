<#
Push-Me.ps1

Run:
  powershell -ExecutionPolicy Bypass -File .\Push-Me.ps1

Behavior:
- Hardcoded Artifactory source + API key inside this script.
- Prompts you for the full .nupkg path.
- Asks whether to Push only, or Delete+Push.
- Uses nuget.exe from PATH (or set $NuGetExePath).
- Shows errors and pauses so the window doesn't close.
#>

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# =========================
# EDIT THESE SETTINGS
# =========================
$NuGetExePath      = ""  # leave empty to use nuget.exe from PATH. Or set e.g. "C:\Tools\nuget.exe"
$ArtifactorySource = "https://<ARTIFACTORY_HOST>/artifactory/api/nuget/<REPO_KEY>"
$ArtifactoryApiKey = "<PASTE_YOUR_API_KEY_OR_TOKEN_HERE>"
# =========================

function Pause-OnExit([string]$Message = "Press any key to close...") {
  Write-Host ""
  Write-Host $Message -ForegroundColor Yellow
  try { $null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown") } catch { Start-Sleep -Seconds 10 }
}

function Resolve-NuGetExe {
  if ([string]::IsNullOrWhiteSpace($NuGetExePath)) {
    $cmd = Get-Command 'nuget' -ErrorAction SilentlyContinue
    if (-not $cmd) { throw "nuget.exe not found in PATH. Add it to PATH or set `$NuGetExePath in the script." }
    return $cmd.Source
  }
  $p = (Resolve-Path -LiteralPath $NuGetExePath -ErrorAction Stop).Path
  if (-not (Test-Path -LiteralPath $p)) { throw "nuget.exe not found at: $p" }
  return $p
}

function Get-PackageIdentityFromFileName([string]$PackagePath) {
  # Best-effort: <id>.<version>.nupkg (version starts at first digit)
  $name = [IO.Path]::GetFileName($PackagePath)
  if (-not $name.ToLowerInvariant().EndsWith('.nupkg')) { return $null }

  $base = $name.Substring(0, $name.Length - '.nupkg'.Length)
  $m = [regex]::Match($base, '^(?<id>.+?)\.(?<ver>\d+\..+)$')
  if (-not $m.Success) { return $null }

  return @{ Id = $m.Groups['id'].Value; Version = $m.Groups['ver'].Value }
}

function Invoke-NuGet([string]$Exe, [string[]]$Args) {
  Write-Host "RUN: $Exe $($Args -join ' ')" -ForegroundColor Cyan
  $p = Start-Process -FilePath $Exe -ArgumentList $Args -NoNewWindow -Wait -PassThru
  if ($p.ExitCode -ne 0) {
    throw "nuget.exe failed (exit $($p.ExitCode))."
  }
}

try {
  # Validate configuration
  if ([string]::IsNullOrWhiteSpace($ArtifactorySource) -or $ArtifactorySource -match '<ARTIFACTORY_HOST>|<REPO_KEY>') {
    throw "Edit `$ArtifactorySource in the script to your real Artifactory NuGet endpoint."
  }
  if ([string]::IsNullOrWhiteSpace($ArtifactoryApiKey) -or $ArtifactoryApiKey -match '<PASTE_YOUR_API_KEY_OR_TOKEN_HERE>') {
    throw "Edit `$ArtifactoryApiKey in the script and paste your real API key/token."
  }

  $nugetExe = Resolve-NuGetExe

  # Prompt for package path (interactive)
  $pkgInput = Read-Host "Enter full path to the .nupkg"
  if ([string]::IsNullOrWhiteSpace($pkgInput)) { throw "No package path provided." }

  $pkgPath = (Resolve-Path -LiteralPath $pkgInput -ErrorAction Stop).Path
  if (-not $pkgPath.ToLowerInvariant().EndsWith('.nupkg')) { throw "Not a .nupkg file: $pkgPath" }

  Write-Host "Package: $pkgPath"
  Write-Host "Source:  $ArtifactorySource"

  # Choose action
  Write-Host ""
  Write-Host "Choose action:"
  Write-Host "  1) Push only (recommended)"
  Write-Host "  2) Delete then Push (only if you have delete rights; breaks immutability)"
  $choice = Read-Host "Enter 1 or 2"

  if ($choice -eq '2') {
    $ident = Get-PackageIdentityFromFileName -PackagePath $pkgPath
    if (-not $ident) {
      throw "Cannot infer PackageId/Version from filename. Rename to <id>.<version>.nupkg (e.g. MyPkg.1.2.3.nupkg) or use push-only."
    }

    $confirm = Read-Host "Type YES to delete '$($ident.Id)' version '$($ident.Version)' from Artifactory"
    if ($confirm -ne 'YES') { throw "Deletion cancelled." }

    $delArgs = @(
      'delete', $ident.Id, $ident.Version,
      '-Source', $ArtifactorySource,
      '-ApiKey', $ArtifactoryApiKey,
      '-NonInteractive',
      '-Verbosity', 'detailed'
    )
    Invoke-NuGet -Exe $nugetExe -Args $delArgs
  }
  elseif ($choice -ne '1') {
    throw "Invalid choice. Enter 1 or 2."
  }

  $pushArgs = @(
    'push', $pkgPath,
    '-Source', $ArtifactorySource,
    '-ApiKey', $ArtifactoryApiKey,
    '-NonInteractive',
    '-Verbosity', 'detailed'
  )
  Invoke-NuGet -Exe $nugetExe -Args $pushArgs

  Write-Host ""
  Write-Host "OK: pushed package." -ForegroundColor Green
  Pause-OnExit
}
catch {
  Write-Host ""
  Write-Host "FAILED" -ForegroundColor Red
  Write-Host $_.Exception.Message -ForegroundColor Red
  Pause-OnExit
  exit 1
}
