# deploy-kill-run.ps1
Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

function Prompt($text, $default = $null) {
    if ($null -ne $default -and $default -ne "") {
        $v = Read-Host "$text [$default]"
        if ([string]::IsNullOrWhiteSpace($v)) { return $default }
        return $v
    }
    return (Read-Host $text)
}

function Ensure-File($path, $label) {
    if (-not (Test-Path -LiteralPath $path -PathType Leaf)) {
        throw "$label not found: $path"
    }
}

function Ensure-Dir($path, $label) {
    if (-not (Test-Path -LiteralPath $path -PathType Container)) {
        throw "$label not found: $path"
    }
}

# ---- ثابتات (عدّلها مرة واحدة فقط) ----
$HostExe = "C:\HOMEWARE\TSMM_DEV\UAT\Current\Unified.Shell.exe"
$DefaultDestDir = "C:\HOMEWARE\TSMM_DEV\UAT\Current\Modules\Volatility"

Ensure-File $HostExe "Host EXE"

Write-Host ""
Write-Host "=== Deploy DLL + PDB (no config), kill Unified.Shell, relaunch ==="
Write-Host ""

# ---- Inputs (prompt) ----
$dllPath = Prompt "Full path to built DLL (e.g. ...\bin\Debug\X.dll)"
Ensure-File $dllPath "DLL"

$destDir = Prompt "Destination folder (runtime load folder)" $DefaultDestDir
Ensure-Dir $destDir "Destination folder"

# Optional args (leave blank usually)
$args = Prompt "Host arguments (optional)" ""

# PDB next to DLL
$pdbPath = [System.IO.Path]::ChangeExtension($dllPath, ".pdb")
$hasPdb  = Test-Path -LiteralPath $pdbPath

Write-Host ""
Write-Host "Will copy:"
Write-Host "  DLL: $dllPath"
if ($hasPdb) { Write-Host "  PDB: $pdbPath" } else { Write-Host "  PDB: (not found) => breakpoints may not bind" }
Write-Host "To:"
Write-Host "  $destDir"

# ---- Kill host processes ----
Write-Host ""
Write-Host "Killing Unified.Shell processes (if any)..."

$procs = Get-Process -Name "Unified.Shell" -ErrorAction SilentlyContinue
if (-not $procs) {
    Write-Host "  None running."
} else {
    foreach ($p in $procs) {
        try {
            Write-Host ("  Stopping PID {0}..." -f $p.Id)
            Stop-Process -Id $p.Id -Force -ErrorAction Stop
        } catch {
            Write-Host ("  Failed to stop PID {0}: {1}" -f $p.Id, $_.Exception.Message)
        }
    }

    Start-Sleep -Milliseconds 500

    $still = Get-Process -Name "Unified.Shell" -ErrorAction SilentlyContinue
    if ($still) {
        Write-Host "  Some instances are still running (likely different user/permissions)."
        $still | ForEach-Object { Write-Host ("    PID {0}" -f $_.Id) }
        Write-Host "  Close them manually if you need to overwrite locked files."
    } else {
        Write-Host "  All Unified.Shell instances stopped."
    }
}

# ---- Backup existing DLL in destination ----
$dllName = Split-Path -Leaf $dllPath
$destDll = Join-Path $destDir $dllName
if (Test-Path -LiteralPath $destDll) {
    $ts = (Get-Date).ToString("yyyyMMdd_HHmmss")
    $bak = "$destDll.bak.$ts"
    Copy-Item -LiteralPath $destDll -Destination $bak -Force
    Write-Host ""
    Write-Host "Backed up existing DLL to:"
    Write-Host "  $bak"
}

# ---- Copy DLL + PDB ----
Write-Host ""
Write-Host "Copying..."
Copy-Item -LiteralPath $dllPath -Destination $destDll -Force
Write-Host ("  Copied {0}" -f $dllName)

if ($hasPdb) {
    $destPdb = Join-Path $destDir (Split-Path -Leaf $pdbPath)
    Copy-Item -LiteralPath $pdbPath -Destination $destPdb -Force
    Write-Host ("  Copied {0}" -f (Split-Path -Leaf $pdbPath))
}

# ---- Launch host ----
Write-Host ""
Write-Host "Launching host..."
$psi = New-Object System.Diagnostics.ProcessStartInfo
$psi.FileName = $HostExe
$psi.WorkingDirectory = Split-Path -Parent $HostExe
$psi.Arguments = $args
$psi.UseShellExecute = $true

[System.Diagnostics.Process]::Start($psi) | Out-Null
Write-Host "Host started."

Write-Host ""
Write-Host "Next:"
Write-Host "  Visual Studio -> Debug -> Attach to Process -> Unified.Shell.exe"
Write-Host "  Debug -> Windows -> Modules -> verify your DLL path and that symbols are loaded"
